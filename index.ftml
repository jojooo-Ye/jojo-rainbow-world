<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Jojo's Rainbow World</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Yuyu+Short&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Black&display=swap" rel="stylesheet">

    <style>
        /* Base Canvas Styles */
        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            background-color: #000000;
            color: #ffffff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow: hidden;
            user-select: none;
        }

        /* Fullscreen DotField Background */
        #dotFieldCanvas {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: 1;
            pointer-events: none;
        }

        /* Page wrapper management */
        .page {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: none;
            justify-content: center;
            align-items: center;
            z-index: 10;
        }

        .page.active {
            display: flex;
        }

        /* --- RAINBOW SWIPE TRANSITION --- */
        #rainbow-transition {
            position: fixed;
            top: 0;
            width: 150%;
            height: 100%;
            background: linear-gradient(90deg, 
                rgba(255,0,0,1) 0%, 
                rgba(255,127,0,1) 16%, 
                rgba(255,255,0,1) 33%, 
                rgba(0,255,0,1) 50%, 
                rgba(0,0,255,1) 66%, 
                rgba(75,0,130,1) 83%, 
                rgba(148,0,211,1) 100%);
            box-shadow: 0 0 100px rgba(255,255,255,0.4);
            z-index: 9999;
            pointer-events: none;
            display: none;
        }

        .swipe-forward-animation {
            display: block !important;
            animation: rainbowSwipeForward 1.6s cubic-bezier(0.42, 0, 0.58, 1) forwards;
        }

        @keyframes rainbowSwipeForward {
            0% { left: 100%; transform: skewX(-15deg); }
            50% { left: -25%; transform: skewX(-15deg); }
            100% { left: -150%; transform: skewX(-15deg); }
        }

        .swipe-backward-animation {
            display: block !important;
            animation: rainbowSwipeBackward 1.6s cubic-bezier(0.42, 0, 0.58, 1) forwards;
        }

        @keyframes rainbowSwipeBackward {
            0% { left: -150%; transform: skewX(15deg); }
            50% { left: -25%; transform: skewX(15deg); }
            100% { left: 100%; transform: skewX(15deg); }
        }

        /* --- PAGE 1 ELEMENTS --- */
        #page-1 { z-index: 12; }
        .container { text-align: center; position: relative; z-index: 15; pointer-events: auto; }
        
        .rainbow-bg {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(1);
            width: 600px;
            height: 300px;
            background: radial-gradient(circle at 50% 100%, 
                rgba(255, 0, 0, 0.4) 0%, rgba(255, 127, 0, 0.4) 15%, rgba(255, 255, 0, 0.4) 30%, 
                rgba(0, 255, 0, 0.4) 45%, rgba(0, 0, 255, 0.4) 60%, rgba(75, 0, 130, 0.4) 75%, rgba(148, 0, 211, 0) 90%);
            border-radius: 300px 300px 0 0;
            filter: blur(30px);
            z-index: -1;
            transition: transform 1.5s cubic-bezier(0.7, 0, 0.3, 1), filter 1.5s ease;
        }

        .canvas-container {
            position: relative;
            width: 95vw;
            height: 180px;
            margin: 0 auto;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        p {
            font-family: 'Yuyu Short', sans-serif;
            font-size: 1.6rem;
            margin-top: 25px;
            color: #cccccc;
            opacity: 0;
            animation: fadeIn 1s ease forwards;
            animation-delay: 1s;
        }

        .rainbow-btn {
            font-family: 'Yuyu Short', sans-serif;
            display: inline-block;
            padding: 14px 42px;
            font-size: 1.5rem;
            font-weight: bold;
            color: white;
            background: linear-gradient(45deg, #ff0000, #ff7f00, #ffff00, #00ff00, #0000ff, #4b0082, #9400d3);
            background-size: 400% 400%;
            border: none;
            border-radius: 50px;
            cursor: pointer;
            box-shadow: 0 0 15px rgba(255,255,255,0.3);
            animation: rainbowShift 5s ease infinite;
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            position: relative;
            z-index: 100;
        }

        .rainbow-btn:hover {
            transform: scale(1.1);
            box-shadow: 0 0 25px rgba(255,255,255,0.7);
        }

        .start-btn {
            margin-top: 35px;
            font-size: 1.9rem;
            padding: 18px 48px;
            opacity: 0;
            animation: fadeIn 1s ease forwards, rainbowShift 5s ease infinite;
            animation-delay: 1.5s;
        }

        .zoom-rainbow { transform: translate(-50%, -50%) scale(6) !important; filter: blur(5px) !important; }

        /* --- PAGE 2 ELEMENTS --- */
        #page-2 { flex-direction: column; }
        
        .board-container {
            background: rgba(255, 255, 255, 0.05);
            padding: 40px;
            border-radius: 25px;
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            text-align: center;
            width: 90%;
            max-width: 520px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
            position: relative;
            z-index: 50;
        }

        .board-container h2 {
            font-family: 'Yuyu Short', sans-serif;
            font-size: 2rem;
        }

        .board-container textarea {
            font-family: 'Yuyu Short', sans-serif;
            width: 100%;
            height: 110px;
            background: rgba(0, 0, 0, 0.6);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            color: white;
            padding: 14px;
            font-size: 1.3rem;
            resize: none;
            box-sizing: border-box;
        }

        .board-container textarea:focus { outline: none; border-color: #ff7f00; }
        .board-container button {
            font-family: 'Yuyu Short', sans-serif;
            margin-top: 20px;
            padding: 12px 32px;
            background: #ffffff;
            border: none;
            border-radius: 24px;
            font-size: 1.3rem;
            font-weight: bold;
            cursor: pointer;
            transition: background 0.2s;
        }
        .board-container button:hover { background: #ff7f00; color: white; }

        .nav-bottom-left { position: absolute; bottom: 30px; left: 30px; z-index: 100; }
        .nav-bottom-right { position: absolute; bottom: 30px; right: 30px; z-index: 100; }

        /* --- PAGE 3 INTERACTIVE GLASS BOOK --- */
        .book-scene {
            perspective: 1500px;
            z-index: 50;
            position: relative;
        }

        .book-container {
            width: 380px;
            height: 480px;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 1s ease, width 1s ease;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            border-radius: 15px;
        }

        .spring-rotate-animation {
            animation: appleSpringShowcase 2.4s cubic-bezier(0.25, 1.5, 0.4, 1) forwards;
        }

        @keyframes appleSpringShowcase {
            0% { transform: rotateY(0deg) scale(1); }
            50% { transform: rotateY(180deg) scale(1.05); }
            100% { transform: rotateY(360deg) scale(1); }
        }

        .book-container.open {
            width: 760px;
            transform: translateX(0);
        }

        .book-cover, .book-inside-left, .book-inside-right {
            position: absolute;
            top: 0;
            width: 50%;
            height: 100%;
            box-sizing: border-box;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(25px);
            -webkit-backdrop-filter: blur(25px);
            border: 2px solid rgba(255, 255, 255, 0.2);
            transition: transform 1s ease;
            backface-visibility: hidden;
            border-radius: 0 15px 15px 0;
        }

        .book-cover {
            width: 100%;
            left: 0;
            background: rgba(255, 255, 255, 0.12);
            border: 3px solid rgba(212, 175, 55, 0.4);
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
            text-align: center;
            transform-origin: left center;
            z-index: 55;
            box-shadow: inset 0 0 30px rgba(255, 255, 255, 0.05);
        }

        .book-cover h2 {
            color: #d4af37;
            font-family: 'Orbitron', sans-serif;
            font-size: 2.2rem;
            font-weight: 700;
            text-shadow: 0 2px 8px rgba(0,0,0,0.6);
            margin-bottom: 40px;
        }

        .book-container.open .book-cover {
            transform: rotateY(-180deg);
        }

        .book-inside-left {
            left: 0;
            width: 50%;
            border-right: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
            opacity: 0;
            transition: opacity 0.5s ease 0.4s;
            border-radius: 15px 0 0 15px;
        }

        .book-inside-right {
            right: 0;
            width: 50%;
            border-left: none;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 25px;
            opacity: 0;
            transition: opacity 0.5s ease 0.4s;
            border-radius: 0 15px 15px 0;
        }

        .book-container.open .book-inside-left,
        .book-container.open .book-inside-right {
            opacity: 1;
        }

        .book-container.open::after {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            width: 2px;
            height: 100%;
            background: linear-gradient(to bottom, transparent, rgba(255,255,255,0.3), transparent);
            z-index: 60;
        }

        .video-intro {
            font-family: 'Yuyu Short', sans-serif;
            font-size: 1.3rem;
            margin-bottom: 15px;
            line-height: 1.4;
            color: #ffffff;
            text-shadow: 0 0 8px rgba(255,255,255,0.4);
            text-align: center;
        }

        video {
            width: 100%;
            max-height: 240px;
            border-radius: 8px;
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 5px 15px rgba(0,0,0,0.5);
            background: #000;
        }

        .book-inside-right p {
            font-family: 'Yuyu Short', sans-serif;
            font-size: 1.25rem !important;
            line-height: 1.6;
            margin-top: 10px;
        }

        .book-inside-right h3 {
            font-family: 'Yuyu Short', sans-serif;
            color: #ff7f00;
            margin-top: 0;
            font-size: 1.6rem;
        }

        .book-side-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.15);
            backdrop-filter: blur(5px);
            border: 1px solid rgba(255,255,255,0.3);
            color: white;
            font-size: 1.8rem;
            font-weight: bold;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 100;
            transition: background 0.3s, transform 0.2s;
            display: none;
        }
        .book-side-nav:hover {
            background: rgba(255, 255, 255, 0.3);
            transform: translateY(-50%) scale(1.1);
        }
        #book-nav-prev { left: -70px; }
        #book-nav-next { right: -70px; }

        /* --- FLYING STARS (USER BULLETS) --- */
        .flying-star {
            font-family: 'Yuyu Short', sans-serif;
            position: absolute;
            white-space: nowrap;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            padding: 10px 22px;
            border-radius: 25px;
            border: 1px solid rgba(255,255,255,0.2);
            box-shadow: 0 0 20px rgba(6, 182, 212, 0.2);
            font-size: 1.3rem;
            cursor: pointer;
            z-index: 60;
            color: #ffffff;
            transition: border-color 0.3s;
            animation: orbit linear infinite;
        }
        .flying-star:hover {
            border-color: #06B6D4;
            box-shadow: 0 0 25px rgba(6, 182, 212, 0.5);
        }

        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        @keyframes rainbowShift {
            0% { background-position: 0% 50% }
            50% { background-position: 100% 50% }
            100% { background-position: 0% 50% }
        }
        @keyframes orbit {
            0% { transform: translate(0, 0) rotate(0deg); }
            25% { transform: translate(180px, -80px) rotate(2deg); }
            50% { transform: translate(90px, 140px) rotate(-2deg); }
            75% { transform: translate(-140px, 60px) rotate(1deg); }
            100% { transform: translate(0, 0) rotate(0deg); }
        }
    </style>
</head>
<body>

    <canvas id="dotFieldCanvas"></canvas>

    <div id="rainbow-transition"></div>

    <div id="page-1" class="page active">
        <div class="container">
            <div class="rainbow-bg" id="rainbow-glow"></div>
            <div class="canvas-container">
                <canvas id="textPressureCanvas"></canvas>
            </div>
            <p>Drag the stars and clouds around with your mouse!</p>
            <button class="rainbow-btn start-btn" id="start-button">Start!</button>
        </div>
    </div>

    <div id="page-2" class="page">
        <div id="p2-star-layer" style="position:absolute; width:100%; height:100%; top:0; left:0; pointer-events:none; z-index:55;"></div>
        
        <div class="board-container">
            <h2 style="margin-top:0;">Jojo's Star Board</h2>
            <textarea id="message-input" placeholder="Share a thought, wish, or greeting..."></textarea>
            <br>
            <button id="submit-message">Send into Orbit ✨</button>
        </div>
        
        <div class="nav-bottom-left">
            <button class="rainbow-btn" id="p2-back">Back</button>
        </div>
        <div class="nav-bottom-right">
            <button class="rainbow-btn" id="p2-next">Next</button>
        </div>
    </div>

    <div id="page-3" class="page">
        <div class="book-scene">
            <button class="book-side-nav" id="book-nav-prev">&lt;</button>
            <button class="book-side-nav" id="book-nav-next">&gt;</button>

            <div class="book-container" id="magical-book">
                <div class="book-cover">
                    <h2>Jojo's magical journey</h2>
                    <button class="rainbow-btn" id="open-book-btn" style="box-shadow: 0 4px 10px rgba(0,0,0,0.2);">Open Book 📖</button>
                </div>
                <div class="book-inside-left">
                    <div class="video-intro">clicking this video to see what is Jojo's last term like!</div>
                    <video controls preload="auto">
                        <source src="g10总结视频.mp4" type="video/mp4">
                        Your browser does not support the video tag or path.
                    </video>
                </div>
                <div class="book-inside-right">
                    <h3>My Memories</h3>
                    <p style="opacity:1; color:#eee;">Welcome to my memory gallery. Flip through my journey pages, thoughts, and school moments!</p>
                </div>
            </div>
        </div>

        <div class="nav-bottom-left">
            <button class="rainbow-btn" id="p3-back">Back</button>
        </div>
    </div>

    <script>
        // --- GLOBAL STATE MOUSE TRACKER ---
        let mouse = { x: -1000, y: -1000 };
        window.addEventListener('mousemove', (e) => { mouse.x = e.clientX; mouse.y = e.clientY; });
        window.addEventListener('touchmove', (e) => { if(e.touches.length > 0) { mouse.x = e.touches[0].clientX; mouse.y = e.touches[0].clientY; } });

        // --- FluidGlass EFFECT TARGET TRACKER ---
        let fluidGlassTarget = null; // Stores ref to active clicked bullet star

        // --- 1. REACT BITS: DOTFIELD BACKGROUND ENGINE ---
        const bgCanvas = document.getElementById('dotFieldCanvas');
        const bgCtx = bgCanvas.getContext('2d');
        let dots = [];

        // Parameter Sync from configuration:
        const dotRadius = 1.5;
        const dotSpacing = 16;
        const bulgeStrength = 103;
        const glowRadius = 160;
        const waveAmplitude = 3;
        const cursorRadius = 400;
        const cursorForce = 0.1;
        const gradientFrom = "#06B6D4";
        const gradientTo = "#B497CF";
        const glowColor = "rgba(6, 182, 212, 0.25)";

        function initDotField() {
            bgCanvas.width = window.innerWidth;
            bgCanvas.height = window.innerHeight;
            dots = [];
            
            for (let x = dotSpacing/2; x < bgCanvas.width; x += dotSpacing) {
                for (let y = dotSpacing/2; y < bgCanvas.height; y += dotSpacing) {
                    dots.push({
                        originX: x,
                        originY: y,
                        x: x,
                        y: y,
                        sparklePhase: Math.random() * Math.PI * 2,
                        sparkleSpeed: 0.02 + Math.random() * 0.04
                    });
                }
            }
        }
        window.addEventListener('resize', initDotField);
        initDotField();

        function drawDotField(time) {
            bgCtx.clearRect(0, 0, bgCanvas.width, bgCanvas.height);
            
            // Draw Mouse Glow Layer
            if (mouse.x > -500) {
                let glowGrad = bgCtx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, glowRadius);
                glowGrad.addColorStop(0, glowColor);
                glowGrad.addColorStop(1, 'transparent');
                bgCtx.fillStyle = glowGrad;
                bgCtx.fillRect(0, 0, bgCanvas.width, bgCanvas.height);
            }

            // Interpolate dynamic color map
            let linearGrad = bgCtx.createLinearGradient(0, 0, bgCanvas.width, bgCanvas.height);
            linearGrad.addColorStop(0, gradientFrom);
            linearGrad.addColorStop(1, gradientTo);
            bgCtx.fillStyle = linearGrad;

            dots.forEach(dot => {
                // Wave distortion logic
                let waveX = Math.sin(time * 0.002 + dot.originY * 0.01) * waveAmplitude;
                let waveY = Math.cos(time * 0.002 + dot.originX * 0.01) * waveAmplitude;
                let targetX = dot.originX + waveX;
                let targetY = dot.originY + waveY;

                // Mouse Force Interaction (Bulge Only mechanics)
                let dx = targetX - mouse.x;
                let dy = targetY - mouse.y;
                let dist = Math.sqrt(dx*dx + dy*dy);

                if (dist < cursorRadius) {
                    let force = (cursorRadius - dist) / cursorRadius;
                    // Apply expansion bulge away from mouse target vector
                    let push = force * bulgeStrength * cursorForce;
                    let angle = Math.atan2(dy, dx);
                    targetX += Math.cos(angle) * push;
                    targetY += Math.sin(angle) * push;
                }

                // FluidGlass Lens Interaction simulation (Pixel Refraction distortion grid mapping)
                if (fluidGlassTarget) {
                    let glassX = fluidGlassTarget.offsetLeft + fluidGlassTarget.offsetWidth / 2;
                    let glassY = fluidGlassTarget.offsetTop + fluidGlassTarget.offsetHeight / 2;
                    let gDx = targetX - glassX;
                    let gDy = targetY - glassY;
                    let gDist = Math.sqrt(gDx*gDx + gDy*gDy);
                    const lensRadius = 130; // Scale 0.25 map bounding box radius

                    if (gDist < lensRadius) {
                        // Apply custom index of refraction (ior: 1.15) vector lens bending formula
                        let progress = gDist / lensRadius;
                        let refract = Math.sin(progress * Math.PI / 2) * 22 * 1.15;
                        let gAngle = Math.atan2(gDy, gDx);
                        
                        // Chromatic Aberration 0.05 color split offset simulation layer
                        bgCtx.fillStyle = "rgba(255, 50, 50, 0.8)";
                        bgCtx.fillRect(targetX + Math.cos(gAngle)*refract*1.05, targetY + Math.sin(gAngle)*refract*1.05, dotRadius, dotRadius);
                        bgCtx.fillStyle = "rgba(50, 255, 255, 0.8)";
                        bgCtx.fillRect(targetX + Math.cos(gAngle)*refract*0.95, targetY + Math.sin(gAngle)*refract*0.95, dotRadius, dotRadius);
                        return; // Bypass native drawing loop for glass pixel aberration
                    }
                }

                // Sparkle cycle phase step
                dot.sparklePhase += dot.sparkleSpeed;
                let currentRadius = dotRadius + Math.sin(dot.sparklePhase) * 0.6;
                if(currentRadius < 0.5) currentRadius = 0.5;

                bgCtx.fillRect(targetX - currentRadius/2, targetY - currentRadius/2, currentRadius, currentRadius);
            });

            // Reset fillStyle mapping back to uniform gradient
            bgCtx.fillStyle = linearGrad;
            requestAnimationFrame(drawDotField);
        }
        requestAnimationFrame(drawDotField);


        // --- 2. TEXT PRESSURE ENGINE ON CANVAS (UPDATED TO ARCHIVO BLACK) ---
        const canvas = document.getElementById('textPressureCanvas');
        const ctx = canvas.getContext('2d');
        const textStr = "Jojo's rainbow world";
        const minFontSize = 62; 
        let letters = [];

        function initTextCanvas() {
            canvas.width = canvas.parentElement.clientWidth;
            canvas.height = 140;
            ctx.font = `900 ${minFontSize}px 'Archivo Black', sans-serif`;
            letters = [];
            
            let totalWidth = 0;
            for(let i=0; i<textStr.length; i++) {
                totalWidth += ctx.measureText(textStr[i]).width + 2;
            }
            let startX = (canvas.width - totalWidth) / 2;
            
            for(let i=0; i<textStr.length; i++) {
                let charW = ctx.measureText(textStr[i]).width;
                letters.push({
                    char: textStr[i],
                    baseX: startX + charW / 2,
                    baseY: 90,
                    scaleX: 1, scaleY: 1,
                    targetScaleX: 1, targetScaleY: 1,
                    vx: 0, vy: 0
                });
                startX += charW + 2;
            }
        }
        window.addEventListener('resize', initTextCanvas);

        const tension = 0.12;
        const friction = 0.78;
        const forceRadius = 180;

        function animateTextPressure() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            ctx.font = `900 ${minFontSize}px 'Archivo Black', sans-serif`;
            ctx.textAlign = "center";
            ctx.textBaseline = "middle";

            // Calculate precise relative coordinates inside canvas view bounds
            const rect = canvas.getBoundingClientRect();
            let cMouseX = mouse.x - rect.left;
            let cMouseY = mouse.y - rect.top;

            letters.forEach((l) => {
                let dx = l.baseX - cMouseX;
                let dy = l.baseY - cMouseY;
                let dist = Math.sqrt(dx*dx + dy*dy);

                if (dist < forceRadius) {
                    let proximity = (forceRadius - dist) / forceRadius; 
                    l.targetScaleX = 1 + proximity * 0.95; // Stretch max width expansion
                    l.targetScaleY = 1 - proximity * 0.45; // Fluid height compression squish
                } else {
                    l.targetScaleX = 1; l.targetScaleY = 1;
                }

                l.vx = (l.vx + (l.targetScaleX - l.scaleX) * tension) * friction;
                l.scaleX += l.vx;
                l.vy = (l.vy + (l.targetScaleY - l.scaleY) * tension) * friction;
                l.scaleY += l.vy;

                ctx.save();
                ctx.translate(l.baseX, l.baseY);
                ctx.scale(l.scaleX, l.scaleY);
                
                ctx.fillStyle = "#ffffff";
                ctx.shadowColor = "rgba(6, 182, 212, 0.6)";
                ctx.shadowBlur = dist < forceRadius ? 20 : 4;
                
                ctx.fillText(l.char, 0, 0);
                ctx.restore();
            });
            requestAnimationFrame(animateTextPressure);
        }

        document.fonts.ready.then(() => {
            initTextCanvas();
            animateTextPressure();
        });


        // --- 3. MAGICAL BOOK INTEGRATIONS ---
        const book = document.getElementById('magical-book');
        const openBookBtn = document.getElementById('open-book-btn');
        const prevBtn = document.getElementById('book-nav-prev');
        const nextBtn = document.getElementById('book-nav-next');
        let isAnimating = false;

        book.addEventListener('mouseenter', () => {
            if (!book.classList.contains('open') && !isAnimating) {
                isAnimating = true;
                book.classList.add('spring-rotate-animation');
                
                setTimeout(() => {
                    book.classList.remove('spring-rotate-animation');
                    isAnimating = false;
                }, 2400);
            }
        });

        openBookBtn.addEventListener('click', (e) => {
            e.stopPropagation();
            if(!isAnimating) {
                book.classList.add('open');
                prevBtn.style.display = 'flex';
                nextBtn.style.display = 'flex';
            }
        });

        prevBtn.addEventListener('click', (e) => { e.stopPropagation(); document.getElementById('p3-back').click(); });
        nextBtn.addEventListener('click', (e) => { e.stopPropagation(); book.classList.remove('open'); hideBookNavs(); });

        function hideBookNavs() { prevBtn.style.display = 'none'; nextBtn.style.display = 'none'; }

        // --- ROUTING PAGE LAYOUT SWITCHER ---
        const page1 = document.getElementById('page-1');
        const page2 = document.getElementById('page-2');
        const page3 = document.getElementById('page-3');
        const rainbowGlow = document.getElementById('rainbow-glow');
        const rainbowTransition = document.getElementById('rainbow-transition');

        function triggerRainbowTransition(fromPage, toPage, direction, finishCallback) {
            const animationClass = direction === 'forward' ? 'swipe-forward-animation' : 'swipe-backward-animation';
            rainbowTransition.classList.add(animationClass);
            
            setTimeout(() => {
                fromPage.classList.remove('active');
                toPage.classList.add('active');
                if (finishCallback) finishCallback();
            }, 800);

            setTimeout(() => { rainbowTransition.classList.remove(animationClass); }, 1600);
        }

        document.getElementById('start-button').addEventListener('click', () => {
            rainbowGlow.classList.add('zoom-rainbow');
            setTimeout(() => { page1.classList.remove('active'); page2.classList.add('active'); }, 1000);
        });

        document.getElementById('p2-back').addEventListener('click', () => {
            page2.classList.remove('active'); page1.classList.add('active');
            rainbowGlow.classList.remove('zoom-rainbow');
        });

        document.getElementById('p2-next').addEventListener('click', () => { triggerRainbowTransition(page2, page3, 'forward'); });
        document.getElementById('p3-back').addEventListener('click', () => {
            triggerRainbowTransition(page3, page2, 'backward', () => { book.classList.remove('open'); hideBookNavs(); });
        });

        // --- DRAG CONTROLLER SYSTEM FOR MESSAGES ---
        function dragElement(elmnt) {
            let pos1 = 0, pos2 = 0, pos3 = 0, pos4 = 0;
            elmnt.onmousedown = dragMouseDown;
            elmnt.ontouchstart = dragMouseDown;

            function dragMouseDown(e) {
                e = e || window.event;
                if (e.type === 'touchstart') {
                    pos3 = e.touches[0].clientX;
                    pos4 = e.touches[0].clientY;
                    document.ontouchend = closeDragElement;
                    document.ontouchmove = elementDrag;
                } else {
                    e.preventDefault();
                    pos3 = e.clientX;
                    pos4 = e.clientY;
                    document.onmouseup = closeDragElement;
                    document.onmousemove = elementDrag;
                }
                elmnt.style.animationPlayState = 'paused';
            }

            function elementDrag(e) {
                e = e || window.event;
                let clientX = e.type === 'touchmove' ? e.touches[0].clientX : e.clientX;
                let clientY = e.type === 'touchmove' ? e.touches[0].clientY : e.clientY;
                pos1 = pos3 - clientX;
                pos2 = pos4 - clientY;
                pos3 = clientX;
                pos4 = clientY;
                elmnt.style.top = (elmnt.offsetTop - pos2) + "px";
                elmnt.style.left = (elmnt.offsetLeft - pos1) + "px";
            }

            function closeDragElement() {
                document.onmouseup = null; document.onmousemove = null;
                document.ontouchend = null; document.ontouchmove = null;
                elmnt.style.animationPlayState = 'running';
            }
        }

        // --- PAGE 2 USER STAR MESSAGE HANDLER + FluidGlass INTERACTION LENS TRIGGER ---
        const submitBtn = document.getElementById('submit-message');
        const messageInput = document.getElementById('message-input');
        const p2StarLayer = document.getElementById('p2-star-layer');

        submitBtn.addEventListener('click', () => {
            const text = messageInput.value.trim();
            if (text === '') return;

            const starText = document.createElement('div');
            starText.classList.add('flying-star');
            starText.style.pointerEvents = 'auto';
            starText.innerHTML = `✨ ${text}`;

            starText.style.left = (10 + Math.random() * 65) + 'vw';
            starText.style.top = (15 + Math.random() * 60) + 'vh';

            const durationSpeed = 14 + Math.random() * 14;
            starText.style.animationDuration = `${durationSpeed}s`;

            // FluidGlass Activation Trigger Hooks
            starText.addEventListener('click', (e) => {
                e.stopPropagation();
                // Toggle active glass lens focus reference targeting
                if (fluidGlassTarget === starText) {
                    fluidGlassTarget = null;
                } else {
                    fluidGlassTarget = starText;
                }
            });

            p2StarLayer.appendChild(starText);
            dragElement(starText);
            messageInput.value = '';
        });

        // Global background click dismisses active refractive FluidGlass lens modifier focus
        window.addEventListener('click', () => { fluidGlassTarget = null; });
    </script>
</body>
</html>
